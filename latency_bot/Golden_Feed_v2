def build_client_from_env() -> Tuple[ClobClient, str]:
    key = os.environ.get("POLYMARKET_PRIVATE_KEY", "").strip()
    if not key:
        raise RuntimeError("POLYMARKET_PRIVATE_KEY missing")
    host = os.environ.get(
        "POLYMARKET_CLOB_HOST", "https://clob.polymarket.com"
    ).strip()
    chain = int(float(os.environ.get("POLYMARKET_CHAIN_ID", "137")))
    funder = os.environ.get("POLYMARKET_PROXY", "").strip() or None
    st_raw = os.environ.get("POLYMARKET_SIGNATURE_TYPE", "").strip()
    signature_type = int(st_raw.lstrip("$")) if st_raw else (1 if funder else 0)
    client = ClobClient(
        host,
        key=key,
        chain_id=chain,
        signature_type=signature_type,
        funder=funder,
    )
    client.set_api_creds(client.create_or_derive_api_creds())
    return client, host


async def warmup_sign(
    loop: asyncio.AbstractEventLoop,
    sign_ex: ThreadPoolExecutor,
    client: ClobClient,
    token_id: str,
) -> None:
    """Pre-warm the signing path to eliminate first-call JIT / lazy-init penalty."""
    try:
        await loop.run_in_executor(
            sign_ex,
            client.create_order,
            OrderArgs(price=0.50, size=1.0, side=BUY, token_id=str(token_id)),
        )
    except Exception:
        pass


async def post_postonly(
    loop: asyncio.AbstractEventLoop,
    sign_ex: ThreadPoolExecutor,
    post_ex: ThreadPoolExecutor,
    client: ClobClient,
    *,
    token_id: str,
    px: float,
    size: float,
    live: bool,
) -> tuple[Optional[str], float, dict[str, Any]]:
    """Sign + post a BUY order with postOnly if supported."""
    t0 = time.perf_counter()

    if not live:
        return None, 0.0, {"mode": "DRY_RUN"}

    signed = await loop.run_in_executor(
        sign_ex,
        client.create_order,
        OrderArgs(
            price=float(px),
            size=float(size),
            side=BUY,
            token_id=str(token_id),
        ),
    )

    def _post_call():
        try:
            return client.post_order(signed, OrderType.GTC, True)
        except TypeError:
            return client.post_order(signed, OrderType.GTC)

    resp = await loop.run_in_executor(post_ex, _post_call)
    dt_ms = (time.perf_counter() - t0) * 1000.0

    oid = None
    out: dict[str, Any]
    if isinstance(resp, dict):
        oid = resp.get("orderID") or resp.get("orderId") or resp.get("id")
        out = dict(resp)
    else:
        out = {"response": str(resp)}

    return (str(oid) if oid else None), dt_ms, out


async def cancel_one(
    loop: asyncio.AbstractEventLoop,
    cancel_ex: ThreadPoolExecutor,
    client: ClobClient,
    order_id: str,
) -> float:
    t0 = time.perf_counter()
    await loop.run_in_executor(cancel_ex, client.cancel_orders, [str(order_id)])
    return (time.perf_counter() - t0) * 1000.0


async def get_order(
    loop: asyncio.AbstractEventLoop,
    read_ex: ThreadPoolExecutor,
    client: ClobClient,
    order_id: str,
) -> Optional[dict[str, Any]]:
    try:
        resp = await loop.run_in_executor(read_ex, client.get_order, str(order_id))
        return resp if isinstance(resp, dict) else None
    except Exception:
        return None


def size_matched(order: Optional[dict[str, Any]]) -> float:
    if not order:
        return 0.0
    sm = order.get("size_matched") or order.get("sizeMatched") or "0"
    try:
        return float(sm)
    except Exception:
        return 0.0


# ── Main market-making loop ──────────────────────────────────────────────────


async def run_one_market(
    args: argparse.Namespace,
    *,
    slug: str,
    up_id: str,
    down_id: str,
    hour_start_et: datetime,
) -> dict[str, Any]:
    loop = asyncio.get_running_loop()

    # Separate thread pools – extra workers so both sides can sign/post/cancel
    # in parallel without head-of-line blocking.
    sign_ex = ThreadPoolExecutor(max_workers=2)
    post_ex = ThreadPoolExecutor(max_workers=2)
    cancel_ex = ThreadPoolExecutor(max_workers=2)
    read_ex = ThreadPoolExecutor(max_workers=1)

    client, host = build_client_from_env()
    jprint({
        "event": "market_resolved",
        "slug": slug,
        "up_token": up_id,
        "down_token": down_id,
        "host": host,
    })

    # ── Warmup signing path for both tokens ──────────────────────────────
    await asyncio.gather(
        warmup_sign(loop, sign_ex, client, up_id),
        warmup_sign(loop, sign_ex, client, down_id),
    )
    jprint({"event": "sign_warmup_done"})

    # ── Shared state ─────────────────────────────────────────────────────
    book_up = BookTop()
    book_dn = BookTop()
    poly_ready = asyncio.Event()

    bin_mid: Optional[float] = None
    bin_ref: Optional[float] = None
    bin_ready = asyncio.Event()

    UP = SideState(name="UP", token_id=up_id)
    DN = SideState(name="DOWN", token_id=down_id)

    # Inventory: net units BOUGHT on each side (increases on fills)
    inventory_up: float = 0.0
    inventory_dn: float = 0.0

    # Cancelled-order audit: when ANY code-path cancels an order we haven't
    # fully fill-checked yet, save it here so fill_watcher can do one final
    # get_order and credit any unaccounted partial fills to inventory.
    #   order_id → (side_name, last_seen_matched_at_detach_time)
    pending_fill_audit: dict[str, tuple[str, float]] = {}

    def detach_order_for_audit(S: SideState) -> Optional[str]:
        """Detach the active order from *S* and save for fill audit.
        Returns the old order_id (or None)."""
        oid = S.order_id
        if oid is not None:
            pending_fill_audit[oid] = (S.name, S.last_seen_matched)
        S.order_id = None
        S.px = None
        S.post_ns = None
        S.size_ordered = 0.0
        S.last_seen_matched = 0.0
        S.post_in_flight = False
        return oid

    def clear_order_no_audit(S: SideState) -> None:
        """Clear order fields without auditing (fills already accounted for)."""
        S.order_id = None
        S.px = None
        S.post_ns = None
        S.size_ordered = 0.0
        S.last_seen_matched = 0.0
        S.post_in_flight = False

    # Volatility tracker
    vol_tracker = VolatilityTracker(
        half_life_ticks=int(args.vol_half_life),
        min_vol=1.0,
        max_vol=200.0,
    )

    # Priority queues
    cancel_q: asyncio.PriorityQueue[tuple[int, int, CancelReq]] = (
        asyncio.PriorityQueue()
    )
    post_q: asyncio.PriorityQueue[tuple[int, int, PostReq]] = (
        asyncio.PriorityQueue()
    )
    seq = 0

    # Metrics
    post_ms_list: list[float] = []
    cancel_ms_list: list[float] = []
    cancel_queue_ms_list: list[float] = []
    trigger_to_cancel_ms_list: list[float] = []
    trigger_to_replace_ms_list: list[float] = []
    fills_up = 0
    fills_dn = 0

    shutdown = asyncio.Event()
    requote_event = asyncio.Event()  # signalled for immediate requote

    # Risk window
    risk_active = False
    risk_dir: Optional[str] = None
    risk_until_ns: Optional[int] = None
    last_risk_trigger_ns: Optional[int] = None

    roll_et = hour_start_et + timedelta(hours=1)

    # ── Pricing helpers ──────────────────────────────────────────────────

    def poly_ok() -> bool:
        return (
            book_up.bid is not None
            and book_up.ask is not None
            and book_dn.bid is not None
            and book_dn.ask is not None
        )

    def book_is_stale(max_age_ms: float) -> bool:
        """Return True if either Poly book is older than *max_age_ms*."""
        t = now_ns()
        for bk in (book_up, book_dn):
            if bk.recv_ns is None:
                return True
            if (t - bk.recv_ns) / 1e6 > max_age_ms:
                return True
        return False

    def mids() -> tuple[float, float]:
        up_mid = 0.5 * (float(book_up.bid) + float(book_up.ask))  # type: ignore[arg-type]
        dn_mid = 0.5 * (float(book_dn.bid) + float(book_dn.ask))  # type: ignore[arg-type]
        return up_mid, dn_mid

    def inventory_skew_ticks() -> tuple[float, float]:
        """
        Per-side skew in ticks based on net inventory.
        If we are long UP, we want to *lower* our UP bid (buy less aggressively)
        so the next fill is more likely to be on DN, rebalancing us.
        Positive return = move price DOWN (less aggressive).
        """
        s = float(args.inventory_skew_ticks)
        return inventory_up * s, inventory_dn * s

    def vol_spread_extra_ticks() -> float:
        """Extra offset ticks to add to each side when vol is elevated."""
        mult = vol_tracker.spread_multiplier(float(args.bin_move_usd))
        # mult >= 1.0; extra = (mult - 1) * scale, capped
        raw = (mult - 1.0) * float(args.vol_spread_scale)
        cap = float(args.vol_spread_max_ticks)
        return min(raw, cap) if cap > 0 else raw

    # ── Quote-mode gating ──────────────────────────────────────────────
    # Modes: "NORMAL" = two-sided quoting
    #        "OFFLOAD" = one-sided (or zero-sided) quoting to flatten inventory
    # In OFFLOAD mode we only buy the side that *completes* pairs.
    # We lock onto the initially-heavy side and never flip: if we
    # overshoot (buy more DN than UP), we idle rather than start
    # buying UP — the minor imbalance on the winning side is a feature.

    last_quote_mode: str = "NORMAL"  # tracks mode for transition detection
    offload_locked_side: Optional[str] = None  # side we locked to in OFFLOAD

    def determine_quote_mode() -> tuple[str, set[str]]:
        """Return (mode, allowed_sides).

        *allowed_sides* is a set of side names ("UP", "DOWN") that the
        quote_manager should post/keep alive.  In NORMAL mode both are
        present; in OFFLOAD only the locked side (if imbalance persists
        in its direction) or empty (idle) if we've paired/overshot.
        Always quotes at full size (args.size).
        """
        nonlocal offload_locked_side

        gate = float(args.prob_gate)
        offload_sec = float(args.offload_last_sec)

        # ── Trigger conditions ─────────────────────────────────────────
        price_gated = False
        if poly_ok():
            up_mid, dn_mid = mids()
            if up_mid < gate or dn_mid < gate:
                price_gated = True

        time_gated = False
        if offload_sec > 0:
            secs_left = (roll_et - datetime.now(ET)).total_seconds()
            if secs_left <= offload_sec:
                time_gated = True

        if not price_gated and not time_gated:
            offload_locked_side = None  # reset lock when returning to NORMAL
            return "NORMAL", {"UP", "DOWN"}

        # ── OFFLOAD: figure out which side to buy ──────────────────────
        unpaired_up = inventory_up - inventory_dn  # >0 means excess UP
        unpaired_dn = inventory_dn - inventory_up  # >0 means excess DN

        # First time entering OFFLOAD (or re-entering after NORMAL): lock
        # onto whichever side is currently heavy.
        if offload_locked_side is None:
            if unpaired_up > 1e-9:
                offload_locked_side = "DOWN"  # buy DN to pair excess UP
            elif unpaired_dn > 1e-9:
                offload_locked_side = "UP"    # buy UP to pair excess DN
            else:
                # Already flat when we enter OFFLOAD → just idle
                return "OFFLOAD", set()

        # Only keep buying the locked side while the original imbalance
        # still exists in that direction.  If we've overshot (flipped),
        # idle — do NOT start buying the other side.
        allowed: set[str] = set()
        if offload_locked_side == "DOWN" and unpaired_up > 1e-9:
            allowed.add("DOWN")
        elif offload_locked_side == "UP" and unpaired_dn > 1e-9:
            allowed.add("UP")
        # else: paired or overshot → idle (allowed stays empty)

        return "OFFLOAD", allowed

    def compute_pair_px() -> Optional[tuple[float, float]]:
        """Compute desired BUY prices for UP and DOWN tokens."""
        if not poly_ok():
            return None
        tick = float(args.tick)
        up_mid, dn_mid = mids()

        # Base offset from mid
        base_off = float(args.mid_offset_ticks) * tick

        # Volatility-adaptive extra offset
        vol_extra = vol_spread_extra_ticks() * tick

        # Inventory skew
        up_skew_t, dn_skew_t = inventory_skew_ticks()

        px_up = up_mid - base_off - vol_extra - up_skew_t * tick
        px_dn = dn_mid - base_off - vol_extra - dn_skew_t * tick

        # Momentum bias: slightly more aggressive on the side above threshold.
        # If a side's mid is >= momentum_threshold (e.g. 0.70), we ADD a small
        # bonus to the bid, making it more likely to fill on the winning side.
        m_thresh = float(args.momentum_threshold)
        m_bonus = float(args.momentum_bonus_ticks) * tick
        if m_bonus > 0 and m_thresh > 0:
            if up_mid >= m_thresh:
                px_up += m_bonus
            if dn_mid >= m_thresh:
                px_dn += m_bonus

        # Maker cap: stay at least ask_buffer_ticks below the best ask
        px_up = min(px_up, float(book_up.ask) - float(args.ask_buffer_ticks) * tick)  # type: ignore[arg-type]
        px_dn = min(px_dn, float(book_dn.ask) - float(args.ask_buffer_ticks) * tick)  # type: ignore[arg-type]

        px_up = normalize_price(px_up, args.price_min, args.price_max, tick)
        px_dn = normalize_price(px_dn, args.price_min, args.price_max, tick)

        # ── Enforce sum constraint (O(1) instead of O(n) loop) ───────────
        target = float(args.sum_target)
        total = px_up + px_dn
        if total > target + 1e-9:
            excess = total - target
            # Distribute excess proportionally
            if total > 1e-12:
                px_up -= excess * (px_up / total)
                px_dn -= excess * (px_dn / total)
            else:
                px_up -= excess / 2.0
                px_dn -= excess / 2.0
            px_up = normalize_price(px_up, args.price_min, args.price_max, tick)
            px_dn = normalize_price(px_dn, args.price_min, args.price_max, tick)
            # Rounding may leave us 1 tick over – one final adjustment
            if px_up + px_dn > target + 1e-9:
                if px_up >= px_dn:
                    px_up = normalize_price(
                        px_up - tick, args.price_min, args.price_max, tick
                    )
                else:
                    px_dn = normalize_price(
                        px_dn - tick, args.price_min, args.price_max, tick
                    )

        return px_up, px_dn

    def risk_replace_px(side: str, base_up: float, base_dn: float) -> float:
        tick = float(args.tick)
        extra = float(args.risk_extra_ticks) * tick
        if side == "UP":
            return normalize_price(
                base_up - extra, args.price_min, args.price_max, tick
            )
        return normalize_price(
            base_dn - extra, args.price_min, args.price_max, tick
        )

    # ── Queue helpers ────────────────────────────────────────────────────

    def enqueue_cancel(
        *,
        prio: int,
        trigger_kind: str,
        side: str,
        oid: str,
        trigger_ns: int,
        replace_px: Optional[float],
        replace_size: Optional[float] = None,
    ) -> None:
        nonlocal seq
        seq += 1
        req = CancelReq(
            prio=prio,
            seq=seq,
            t_enqueue_ns=now_ns(),
            t_trigger_ns=int(trigger_ns),
            trigger_kind=trigger_kind,
            side=side,
            order_id=oid,
            replace_px=replace_px,
            replace_size=replace_size,
        )
        cancel_q.put_nowait((req.prio, req.seq, req))

    def enqueue_post(
        *,
        prio: int,
        trigger_kind: str,
        side: str,
        token_id: str,
        px: float,
        trigger_ns: int,
        size: Optional[float] = None,
    ) -> None:
        nonlocal seq
        S = UP if side == "UP" else DN
        S.post_in_flight = True  # prevent duplicate enqueues until post_worker clears
        seq += 1
        req = PostReq(
            prio=prio,
            seq=seq,
            t_enqueue_ns=now_ns(),
            trigger_ns=int(trigger_ns),
            trigger_kind=trigger_kind,
            side=side,
            token_id=token_id,
            px=float(px),
            size=float(size) if size is not None else float(args.size),
        )
        post_q.put_nowait((req.prio, req.seq, req))

    # ── Cancel worker (2 instances for parallelism) ──────────────────────

    async def cancel_worker() -> None:
        while not shutdown.is_set():
            try:
                _, _, req = await asyncio.wait_for(cancel_q.get(), timeout=0.5)
            except asyncio.TimeoutError:
                continue

            t_start = now_ns()
            cancel_queue_ms_list.append((t_start - req.t_enqueue_ns) / 1e6)

            S = UP if req.side == "UP" else DN
            cancel_ok = False

            try:
                ms = await cancel_one(loop, cancel_ex, client, req.order_id)
                cancel_ms_list.append(ms)
                trigger_to_cancel_ms_list.append(
                    (now_ns() - req.t_trigger_ns) / 1e6
                )
                cancel_ok = True

                jprint({
                    "event": "cancel_done",
                    "side": req.side,
                    "oid": req.order_id,
                    "prio": "HI" if req.prio == 0 else "LO",
                    "trigger_kind": req.trigger_kind,
                    "cancel_ms": ms,
                    "queue_ms": cancel_queue_ms_list[-1],
                    "trigger_to_cancel_ms": trigger_to_cancel_ms_list[-1],
                })
            except Exception as e:
                jprint({
                    "event": "cancel_error",
                    "side": req.side,
                    "oid": req.order_id,
                    "err": str(e),
                })

            if not cancel_ok:
                # Cancel may not have gone through — old order could still be
                # live on the exchange.  Restore tracking so we don't orphan it
                # and let quote_manager retry on the next cycle.
                if S.order_id is None and not S.post_in_flight:
                    S.order_id = req.order_id
                    # Remove from audit — we're restoring, not abandoning
                    pending_fill_audit.pop(req.order_id, None)
                S.cancel_in_flight = False
                jprint({
                    "event": "cancel_restore",
                    "side": req.side,
                    "oid": req.order_id,
                })
                continue  # do NOT post replacement

            S.cancel_in_flight = False

            # Schedule replacement on post lane (so cancels can't be blocked
            # by a slow post).
            if req.replace_px is not None:
                enqueue_post(
                    prio=0,
                    trigger_kind=req.trigger_kind,
                    side=req.side,
                    token_id=S.token_id,
                    px=float(req.replace_px),
                    trigger_ns=req.t_trigger_ns,
                    size=req.replace_size,  # None → default (args.size); set for partials
                )
            else:
                # No replace price → signal requote so quote_manager re-posts
                # immediately (e.g. after a fill cancel).
                requote_event.set()

    # ── Post worker (2 instances for parallelism) ────────────────────────

    async def post_worker() -> None:
        while not shutdown.is_set():
            try:
                _, _, req = await asyncio.wait_for(post_q.get(), timeout=0.5)
            except asyncio.TimeoutError:
                continue

            S = UP if req.side == "UP" else DN

            # ── Duplicate guard: another post for this side already landed ──
            if S.order_id is not None:
                S.post_in_flight = False
                jprint({
                    "event": "post_skipped_dup",
                    "side": req.side,
                    "existing_oid": S.order_id,
                    "trigger_kind": req.trigger_kind,
                })
                continue

            # ── Stale-data guard: skip post if book data is too old ─────────
            if book_is_stale(float(args.stale_book_ms)):
                S.post_in_flight = False
                jprint({
                    "event": "post_skipped_stale_book",
                    "side": req.side,
                    "trigger_kind": req.trigger_kind,
                })
                continue

            try:
                oid, ms, resp = await post_postonly(
                    loop,
                    sign_ex,
                    post_ex,
                    client,
                    token_id=req.token_id,
                    px=req.px,
                    size=req.size,
                    live=bool(args.live),
                )
            except Exception as e:
                S.post_in_flight = False
                jprint({
                    "event": "post_error",
                    "side": req.side,
                    "trigger_kind": req.trigger_kind,
                    "err": str(e),
                })
                continue

            post_ms_list.append(ms)

            S.order_id = oid
            S.px = req.px
            S.post_ns = now_ns()
            S.size_ordered = req.size
            S.last_seen_matched = 0.0
            S.post_in_flight = False

            if req.trigger_kind in (
                "BIN",
                "FILL",
                "REQUOTE",
                "FILL_REPOST",
                "RISK_CLEAR",
                "STALE",
                "PARTIAL",
                "PARTIAL_REPOST",
                "GATE",
                "GATE_RESIZE",
            ):
                trigger_to_replace_ms_list.append(
                    (now_ns() - req.trigger_ns) / 1e6
                )

            jprint({
                "event": "post",
                "side": req.side,
                "px": req.px,
                "size": req.size,
                "post_ms": ms,
                "oid": oid,
                "prio": "HI" if req.prio == 0 else "LO",
                "trigger_kind": req.trigger_kind,
                "resp": resp,
                "trigger_to_replace_ms": (
                    trigger_to_replace_ms_list[-1]
                    if trigger_to_replace_ms_list
                    else None
                ),
            })

    # ── Polymarket WebSocket (with reconnect) ────────────────────────────

    async def poly_ws() -> None:
        token_ids = [up_id, down_id]
        while not shutdown.is_set():
            try:
                async with websockets.connect(
                    POLY_WS,
                    ssl=SSL_CTX,
                    ping_interval=15,
                    ping_timeout=20,
                    max_queue=1,
                    compression=None,
                    close_timeout=3,
                    open_timeout=10,
                ) as ws:
                    await ws.send(
                        json.dumps({"type": "market", "assets_ids": token_ids})
                    )
                    jprint({"event": "poly_ws_subscribed", "slug": slug})
                    async for raw in ws:
                        if shutdown.is_set():
                            return
                        recv = now_ns()
                        msg = _json_loads(raw)
                        items = msg if isinstance(msg, list) else [msg]
                        for d in items:
                            if not isinstance(d, dict):
                                continue
                            if str(d.get("event_type", "")).lower() != "book":
                                continue
                            aid = str(d.get("asset_id", ""))
                            bids = d.get("bids") or d.get("buys") or []
                            asks = d.get("asks") or d.get("sells") or []
                            bb = best_from_levels(bids, True)
                            ba = best_from_levels(asks, False)
                            if bb is None or ba is None:
                                continue
                            if aid == up_id:
                                book_up.bid = float(bb)
                                book_up.ask = float(ba)
                                book_up.recv_ns = int(recv)
                            elif aid == down_id:
                                book_dn.bid = float(bb)
                                book_dn.ask = float(ba)
                                book_dn.recv_ns = int(recv)
                        if poly_ok():
                            poly_ready.set()
            except Exception as e:
                jprint({"event": "poly_ws_error", "err": str(e)})
                if not shutdown.is_set():
                    await asyncio.sleep(1.0)

    # ── Binance WebSocket (with reconnect across both URLs) ──────────────

    async def bin_ws() -> None:
        nonlocal bin_mid, bin_ref
        nonlocal risk_active, risk_dir, risk_until_ns, last_risk_trigger_ns
        urls = [
            f"{BINANCE_WS_PRIMARY}/{BINANCE_SYMBOL}@bookTicker",
            f"{BINANCE_WS_FALLBACK}/{BINANCE_SYMBOL}@bookTicker",
        ]
        while not shutdown.is_set():
            for url in urls:
                if shutdown.is_set():
                    return
                try:
                    async with websockets.connect(
                        url,
                        ssl=SSL_CTX,
                        ping_interval=15,
                        ping_timeout=20,
                        max_queue=1,
                        compression=None,
                        close_timeout=3,
                        open_timeout=10,
                    ) as ws:
                        jprint({"event": "bin_ws_connected", "url": url})
                        async for raw in ws:
                            if shutdown.is_set():
                                return
                            t = now_ns()
                            d = _json_loads(raw)
                            b = float(d["b"])
                            a = float(d["a"])
                            new_mid = 0.5 * (b + a)

                            # Update volatility tracker on every tick
                            vol_tracker.update(new_mid)

                            bin_mid = new_mid
                            if not bin_ready.is_set():
                                bin_ready.set()

                            if bin_ref is None:
                                continue

                            # ── Risk-timer clear (checked every tick) ────
                            if (
                                risk_active
                                and risk_until_ns is not None
                                and t >= risk_until_ns
                            ):
                                risk_active = False
                                risk_dir = None
                                risk_until_ns = None
                                last_risk_trigger_ns = None
                                bin_ref = float(bin_mid)
                                jprint({
                                    "event": "risk_clear_timer",
                                    "t_ns": int(t),
                                    "bin_ref": bin_ref,
                                })
                                # Trigger immediate requote
                                requote_event.set()

                            if risk_active:
                                continue

                            # ── Decay bin_ref toward current mid ─────────
                            decay = float(args.bin_ref_decay)
                            if 0.0 < decay < 1.0:
                                bin_ref = (
                                    bin_ref * (1.0 - decay) + bin_mid * decay
                                )

                            # ── Check for adverse BTC move ───────────────
                            move = float(bin_mid) - float(bin_ref)
                            if abs(move) < float(args.bin_move_usd):
                                continue

                            risk_active = True
                            last_risk_trigger_ns = int(t)
                            risk_until_ns = int(
                                t + int(float(args.risk_hold_ms) * 1e6)
                            )
                            risk_dir = "up" if move > 0 else "down"

                            jprint({
                                "event": "risk_trigger",
                                "dir": risk_dir,
                                "move_usd": move,
                                "vol_ema": vol_tracker.ema,
                                "t_ns": int(t),
                            })

                            q = compute_pair_px()
                            if q is None:
                                # Reset ref so we don't re-trigger immediately
                                bin_ref = float(bin_mid)
                                continue
                            base_up, base_dn = q

                            # Adverse side: DOWN when BTC goes up, UP when
                            # BTC goes down.
                            adverse = "DOWN" if risk_dir == "up" else "UP"
                            S = DN if adverse == "DOWN" else UP

                            if S.order_id and not S.cancel_in_flight:
                                S.cancel_in_flight = True
                                old_oid = detach_order_for_audit(S)

                                repl = risk_replace_px(
                                    adverse, base_up, base_dn
                                )
                                enqueue_cancel(
                                    prio=0,
                                    trigger_kind="BIN",
                                    side=adverse,
                                    oid=str(old_oid),
                                    trigger_ns=int(t),
                                    replace_px=repl,
                                )

                            # Anchor ref to current mid after triggering
                            bin_ref = float(bin_mid)

                except Exception as e:
                    jprint({
                        "event": "bin_ws_error",
                        "url": url,
                        "err": str(e),
                    })
                    if not shutdown.is_set():
                        await asyncio.sleep(1.0)

    # ── Risk-timer watchdog ──────────────────────────────────────────────
    # Independent timer that clears risk even if Binance WS goes quiet.

    async def risk_timer_watchdog() -> None:
        nonlocal risk_active, risk_dir, risk_until_ns
        nonlocal last_risk_trigger_ns, bin_ref
        while not shutdown.is_set():
            await asyncio.sleep(0.010)  # 10 ms check interval
            if not risk_active or risk_until_ns is None:
                continue
            if now_ns() >= risk_until_ns:
                risk_active = False
                risk_dir = None
                risk_until_ns = None
                last_risk_trigger_ns = None
                if bin_mid is not None:
                    bin_ref = float(bin_mid)
                jprint({"event": "risk_clear_watchdog", "bin_ref": bin_ref})
                requote_event.set()

    # ── Fill detection (handles partial + full fills) ────────────────────

    async def fill_watcher() -> None:
        nonlocal inventory_up, inventory_dn, fills_up, fills_dn
        while not shutdown.is_set():
            await asyncio.sleep(float(args.fill_poll_ms) / 1000.0)

            # ── 1. Audit cancelled orders for unaccounted partial fills ──
            # When any code-path cancels an order (BIN, REQUOTE, STALE,
            # ROLLOVER), it may not have polled get_order recently.  We do
            # one final check here so those fills aren't lost.
            audit_ids = list(pending_fill_audit.keys())
            for oid in audit_ids:
                side_name, prev_matched = pending_fill_audit[oid]
                od = await get_order(loop, read_ex, client, oid)
                final_matched = size_matched(od)
                new_fill = final_matched - prev_matched
                if new_fill > 1e-9:
                    if side_name == "UP":
                        inventory_up += new_fill
                    else:
                        inventory_dn += new_fill
                    jprint({
                        "event": "audit_fill",
                        "side": side_name,
                        "oid": oid,
                        "prev_matched": prev_matched,
                        "final_matched": final_matched,
                        "credited": new_fill,
                    })
                    # Inventory changed → signal requote so quotes adjust
                    requote_event.set()
                del pending_fill_audit[oid]

            # ── 2. Check active orders for incremental fills ─────────────
            for S, other, side_name, other_name in [
                (UP, DN, "UP", "DOWN"),
                (DN, UP, "DOWN", "UP"),
            ]:
                if not S.order_id:
                    continue

                od = await get_order(loop, read_ex, client, S.order_id)
                current_matched = size_matched(od)
                new_fill = current_matched - S.last_seen_matched

                if new_fill < 1e-9:
                    continue  # no new fill since last check

                # ── Credit the new fill increment to inventory ───────────
                S.last_seen_matched = current_matched
                if side_name == "UP":
                    inventory_up += new_fill
                else:
                    inventory_dn += new_fill

                remaining = S.size_ordered - current_matched
                is_full = remaining < float(args.min_remaining_size)

                if is_full:
                    # ── FULL FILL (or remainder too small to bother) ─────
                    jprint({
                        "event": "fill",
                        "side": side_name,
                        "oid": S.order_id,
                        "matched": current_matched,
                        "remaining": remaining,
                        "type": "full",
                        "inventory_up": inventory_up,
                        "inventory_dn": inventory_dn,
                    })
                    if side_name == "UP":
                        fills_up += 1
                    else:
                        fills_dn += 1

                    # Fills already credited above – just clear state
                    clear_order_no_audit(S)

                    if args.cancel_other_on_fill:
                        if other.order_id and not other.cancel_in_flight:
                            other.cancel_in_flight = True
                            oid = detach_order_for_audit(other)
                            if oid:
                                enqueue_cancel(
                                    prio=0,
                                    trigger_kind="FILL",
                                    side=other_name,
                                    oid=str(oid),
                                    trigger_ns=now_ns(),
                                    replace_px=None,
                                )

                    # Re-post with fresh prices (mode-aware, full size)
                    fill_mode, fill_allowed = determine_quote_mode()
                    if side_name in fill_allowed:
                        q = compute_pair_px()
                        if q is not None:
                            px_up, px_dn = q
                            my_px = px_up if side_name == "UP" else px_dn
                            enqueue_post(
                                prio=0,
                                trigger_kind="FILL_REPOST",
                                side=side_name,
                                token_id=S.token_id,
                                px=my_px,
                                trigger_ns=now_ns(),
                            )
                    requote_event.set()

                else:
                    # ── PARTIAL FILL ─────────────────────────────────────
                    jprint({
                        "event": "partial_fill",
                        "side": side_name,
                        "oid": S.order_id,
                        "new_fill": new_fill,
                        "total_matched": current_matched,
                        "remaining": remaining,
                        "inventory_up": inventory_up,
                        "inventory_dn": inventory_dn,
                    })

                    if args.partial_fill_reprice:
                        # Cancel the remaining resting qty and re-post at an
                        # inventory-skew-adjusted price with reduced size.
                        S.cancel_in_flight = True
                        old_oid = S.order_id
                        # We've already credited all fills – no audit needed
                        S.order_id = None
                        S.px = None
                        S.post_ns = None
                        S.size_ordered = 0.0
                        S.last_seen_matched = 0.0

                        q = compute_pair_px()
                        if q is not None:
                            px_up, px_dn = q
                            new_px = px_up if side_name == "UP" else px_dn
                            enqueue_cancel(
                                prio=0,
                                trigger_kind="PARTIAL",
                                side=side_name,
                                oid=str(old_oid),
                                trigger_ns=now_ns(),
                                replace_px=float(new_px),
                                replace_size=float(remaining),
                            )
                        else:
                            # Can't compute price – cancel without replace,
                            # quote_manager will re-post later.
                            enqueue_cancel(
                                prio=0,
                                trigger_kind="PARTIAL",
                                side=side_name,
                                oid=str(old_oid),
                                trigger_ns=now_ns(),
                                replace_px=None,
                            )
                    else:
                        # Leave the resting order alone; just signal requote
                        # so the *other* side adjusts to our new inventory.
                        requote_event.set()

    # ── Quote manager ────────────────────────────────────────────────────

    async def quote_manager() -> None:
        nonlocal bin_ref, last_quote_mode
        await bin_ready.wait()
        await poly_ready.wait()

        if bin_mid is not None:
            bin_ref = float(bin_mid)

        jprint({
            "event": "quote_start",
            "bin_ref": bin_ref,
            "sum_target": args.sum_target,
            "mid_offset_ticks": args.mid_offset_ticks,
            "ask_buffer_ticks": args.ask_buffer_ticks,
            "vol_ema": vol_tracker.ema,
        })

        last_tick_ns = 0

        # ── Initial posts (only for allowed sides) ─────────────────────
        mode, allowed = determine_quote_mode()
        last_quote_mode = mode

        q = compute_pair_px()
        if q is not None:
            px_up, px_dn = q
            if "UP" in allowed:
                enqueue_post(
                    prio=1,
                    trigger_kind="INIT",
                    side="UP",
                    token_id=UP.token_id,
                    px=px_up,
                    trigger_ns=now_ns(),
                )
            if "DOWN" in allowed:
                enqueue_post(
                    prio=1,
                    trigger_kind="INIT",
                    side="DOWN",
                    token_id=DN.token_id,
                    px=px_dn,
                    trigger_ns=now_ns(),
                )

        while not shutdown.is_set():
            # Wait for either the periodic interval OR an immediate requote
            # signal (from fill, risk-clear, cancel-without-replace, etc.)
            try:
                await asyncio.wait_for(
                    requote_event.wait(),
                    timeout=float(args.quote_interval_ms) / 1000.0,
                )
                requote_event.clear()
            except asyncio.TimeoutError:
                pass

            t = now_ns()
            if (t - last_tick_ns) < int(float(args.quote_min_gap_ms) * 1e6):
                continue
            last_tick_ns = t

            if risk_active:
                continue

            # Stale data guard
            if book_is_stale(float(args.stale_book_ms)):
                continue

            # ── Determine quote mode ──────────────────────────────────
            mode, allowed = determine_quote_mode()

            if mode != last_quote_mode:
                jprint({
                    "event": "mode_change",
                    "from": last_quote_mode,
                    "to": mode,
                    "allowed_sides": sorted(allowed),
                    "inventory_up": inventory_up,
                    "inventory_dn": inventory_dn,
                })
                last_quote_mode = mode

            q = compute_pair_px()
            if q is None:
                continue
            px_up, px_dn = q
            tick = float(args.tick)
            max_age_ns = int(float(args.order_max_age_ms) * 1e6)

            for side, desired_px, name in [
                (UP, px_up, "UP"),
                (DN, px_dn, "DOWN"),
            ]:
                is_allowed = name in allowed

                # ── CANCEL side that is NOT allowed in current mode ────
                if not is_allowed:
                    if (
                        side.order_id is not None
                        and not side.cancel_in_flight
                    ):
                        side.cancel_in_flight = True
                        oid = detach_order_for_audit(side)
                        if oid:
                            enqueue_cancel(
                                prio=0,
                                trigger_kind="GATE",
                                side=name,
                                oid=str(oid),
                                trigger_ns=now_ns(),
                                replace_px=None,  # no replacement
                            )
                    continue

                if side.cancel_in_flight:
                    continue
                if side.post_in_flight:
                    continue

                if side.order_id is None:
                    # No resting order and no post queued → post
                    enqueue_post(
                        prio=1,
                        trigger_kind="REQUOTE",
                        side=name,
                        token_id=side.token_id,
                        px=desired_px,
                        trigger_ns=now_ns(),
                    )
                    continue

                # Check if order needs repricing (price moved >= 1 tick)
                needs_reprice = (
                    side.px is not None
                    and abs(float(side.px) - float(desired_px)) >= tick - 1e-12
                )

                # Check if order has been resting too long (adverse-selection
                # risk increases with time; refreshing forces re-queue)
                is_stale_order = (
                    max_age_ns > 0
                    and side.post_ns is not None
                    and (t - side.post_ns) > max_age_ns
                )

                if needs_reprice or is_stale_order:
                    side.cancel_in_flight = True
                    oid = detach_order_for_audit(side)
                    enqueue_cancel(
                        prio=1,
                        trigger_kind="STALE" if is_stale_order else "REQUOTE",
                        side=name,
                        oid=str(oid),
                        trigger_ns=now_ns(),
                        replace_px=float(desired_px),
                    )

    # ── Rollover ─────────────────────────────────────────────────────────

    async def roller() -> None:
        while not shutdown.is_set():
            await asyncio.sleep(0.25)
            if datetime.now(ET) >= roll_et:
                jprint({"event": "rollover", "at": roll_et.isoformat()})
                # Cancel all outstanding orders before rolling
                for S, name in [(UP, "UP"), (DN, "DOWN")]:
                    if S.order_id and not S.cancel_in_flight:
                        S.cancel_in_flight = True
                        oid = detach_order_for_audit(S)
                        if oid:
                            enqueue_cancel(
                                prio=0,
                                trigger_kind="ROLLOVER",
                                side=name,
                                oid=str(oid),
                                trigger_ns=now_ns(),
                                replace_px=None,
                            )
                # Give cancels time to process before tearing down
                await asyncio.sleep(0.5)
                shutdown.set()
                return

    # ── Periodic stats ───────────────────────────────────────────────────

    async def periodic() -> None:
        while not shutdown.is_set():
            await asyncio.sleep(float(args.summary_every_sec))
            # Show spread breakdown so user can see exactly what's widening
            up_skew_t, dn_skew_t = inventory_skew_ticks()
            vol_extra_t = vol_spread_extra_ticks()
            tick = float(args.tick)
            mode, allowed = determine_quote_mode()
            secs_left = (roll_et - datetime.now(ET)).total_seconds()

            # Momentum bonus (informational, mirrors compute_pair_px logic)
            m_thresh = float(args.momentum_threshold)
            m_bonus_t = float(args.momentum_bonus_ticks)
            up_momentum_t = m_bonus_t if (poly_ok() and mids()[0] >= m_thresh) else 0.0
            dn_momentum_t = m_bonus_t if (poly_ok() and mids()[1] >= m_thresh) else 0.0

            jprint({
                "event": "rolling",
                "quote_mode": mode,
                "allowed_sides": sorted(allowed),
                "secs_to_roll": round(secs_left, 1),
                "post_ms": summarize(post_ms_list[-200:]),
                "cancel_ms": summarize(cancel_ms_list[-200:]),
                "cancel_queue_ms": summarize(cancel_queue_ms_list[-200:]),
                "trigger_to_cancel_ms": summarize(
                    trigger_to_cancel_ms_list[-200:]
                ),
                "trigger_to_replace_ms": summarize(
                    trigger_to_replace_ms_list[-200:]
                ),
                "risk_active": risk_active,
                "risk_dir": risk_dir,
                "spread_breakdown": {
                    "mid_offset_ticks": float(args.mid_offset_ticks),
                    "vol_extra_ticks": round(vol_extra_t, 3),
                    "up_skew_ticks": round(up_skew_t, 3),
                    "dn_skew_ticks": round(dn_skew_t, 3),
                    "up_momentum_ticks": round(up_momentum_t, 3),
                    "dn_momentum_ticks": round(dn_momentum_t, 3),
                    "net_offset_up": round(
                        (float(args.mid_offset_ticks) + vol_extra_t + up_skew_t - up_momentum_t) * tick, 4
                    ),
                    "net_offset_dn": round(
                        (float(args.mid_offset_ticks) + vol_extra_t + dn_skew_t - dn_momentum_t) * tick, 4
                    ),
                },
                "vol_ema": vol_tracker.ema,
                "UP_px": UP.px,
                "DN_px": DN.px,
                "inventory_up": inventory_up,
                "inventory_dn": inventory_dn,
                "fills_up": fills_up,
                "fills_dn": fills_dn,
                "UP_oid": UP.order_id is not None,
                "DN_oid": DN.order_id is not None,
            })

    # ── Launch all tasks ─────────────────────────────────────────────────

    tasks = [
        asyncio.create_task(cancel_worker(), name="cancel_1"),
        asyncio.create_task(cancel_worker(), name="cancel_2"),
        asyncio.create_task(post_worker(), name="post_1"),
        asyncio.create_task(post_worker(), name="post_2"),
        asyncio.create_task(poly_ws(), name="poly_ws"),
        asyncio.create_task(bin_ws(), name="bin_ws"),
        asyncio.create_task(risk_timer_watchdog(), name="risk_watchdog"),
        asyncio.create_task(fill_watcher(), name="fill_watcher"),
        asyncio.create_task(quote_manager(), name="quote_manager"),
        asyncio.create_task(roller(), name="roller"),
        asyncio.create_task(periodic(), name="periodic"),
    ]

    final_state: dict[str, Any] = {}
    try:
        await shutdown.wait()
    except asyncio.CancelledError:
        pass  # normal shutdown path
    finally:
        for t in tasks:
            t.cancel()
        await asyncio.gather(*tasks, return_exceptions=True)
        sign_ex.shutdown(wait=False, cancel_futures=True)
        post_ex.shutdown(wait=False, cancel_futures=True)
        cancel_ex.shutdown(wait=False, cancel_futures=True)
        read_ex.shutdown(wait=False, cancel_futures=True)

        final_state = {
            "slug": slug,
            "up_token_id": up_id,
            "down_token_id": down_id,
            "inventory_up": inventory_up,
            "inventory_dn": inventory_dn,
            "fills_up": fills_up,
            "fills_dn": fills_dn,
            "roll_et": roll_et.isoformat(),
            "hour_start_et": hour_start_et.isoformat(),
        }

        # Write state file for the liquidator
        try:
            safe_slug = slug.replace("/", "_").replace("\\", "_")
            state_path = Path(args.state_dir) / f"state_{safe_slug}.json"
            state_path.write_text(
                json.dumps(final_state, indent=2, default=str),
                encoding="utf-8",
            )
            jprint({"event": "state_written", "path": str(state_path)})
        except Exception as e:
            jprint({"event": "state_write_error", "err": str(e)})

        jprint({
            "event": "summary",
            "slug": slug,
            "post_ms": summarize(post_ms_list),
            "cancel_ms": summarize(cancel_ms_list),
            "cancel_queue_ms": summarize(cancel_queue_ms_list),
            "trigger_to_cancel_ms": summarize(trigger_to_cancel_ms_list),
            "trigger_to_replace_ms": summarize(trigger_to_replace_ms_list),
            "inventory_up": inventory_up,
            "inventory_dn": inventory_dn,
            "fills_up": fills_up,
            "fills_dn": fills_dn,
        })

    return final_state


# ── CLI ──────────────────────────────────────────────────────────────────────


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="HFT spread-capture market maker for Polymarket hourly BTC markets"
    )
    p.add_argument("--env-file", required=True)

    p.add_argument("--walk-hours-forward", type=int, default=6)
    p.add_argument("--gamma-timeout-sec", type=float, default=8.0)

    p.add_argument("--live", action="store_true")
    p.add_argument("--size", type=float, default=5.0)

    p.add_argument("--tick", type=float, default=0.01)
    p.add_argument("--price-min", type=float, default=0.01)
    p.add_argument("--price-max", type=float, default=0.99)

    p.add_argument("--sum-target", type=float, default=0.995)
    p.add_argument("--mid-offset-ticks", type=float, default=0.0)
    p.add_argument("--ask-buffer-ticks", type=float, default=1.0)

    p.add_argument("--bin-move-usd", type=float, default=5.0)
    p.add_argument("--risk-extra-ticks", type=int, default=0)
    p.add_argument("--risk-hold-ms", type=float, default=250.0)

    # Volatility-adaptive spread
    p.add_argument(
        "--vol-half-life",
        type=int,
        default=50,
        help="EMA half-life in Binance ticks for volatility tracker",
    )
    p.add_argument(
        "--vol-spread-scale",
        type=float,
        default=0.3,
        help="Extra offset ticks per unit of vol multiplier above 1.0",
    )
    p.add_argument(
        "--vol-spread-max-ticks",
        type=float,
        default=1.0,
        help="Hard cap on vol-adaptive spread widening in ticks (prevents blowout)",
    )

    # Momentum bias
    p.add_argument(
        "--momentum-threshold",
        type=float,
        default=0.70,
        help="Mid price above which the side gets a bonus bid (default: 0.70)",
    )
    p.add_argument(
        "--momentum-bonus-ticks",
        type=float,
        default=0.3,
        help="Extra ticks to bid UP (more aggressive) on the winning side (default: 0.3)",
    )

    # Inventory skew
    p.add_argument(
        "--inventory-skew-ticks",
        type=float,
        default=0.15,
        help="Ticks to skew per unit of inventory (positive = less aggressive)",
    )
    p.add_argument(
        "--cancel-other-on-fill",
        action="store_true",
        default=True,
        help="Cancel the other side's order when one side fills (default: True)",
    )
    p.add_argument(
        "--no-cancel-other-on-fill",
        dest="cancel_other_on_fill",
        action="store_false",
        help="Keep the other side's order alive after a fill (pure spread capture)",
    )

    # Partial fill behaviour
    p.add_argument(
        "--partial-fill-reprice",
        action="store_true",
        default=True,
        help="On partial fill: cancel remaining, reprice at inventory-skewed level with reduced size (default: True)",
    )
    p.add_argument(
        "--no-partial-fill-reprice",
        dest="partial_fill_reprice",
        action="store_false",
        help="On partial fill: leave resting order alone, only update inventory & signal requote for other side",
    )
    p.add_argument(
        "--min-remaining-size",
        type=float,
        default=0.5,
        help="Remaining order size below this is treated as a full fill (default: 0.5)",
    )

    # Offload / gating
    p.add_argument(
        "--prob-gate",
        type=float,
        default=0.10,
        help="When either side's mid dips below this, stop two-sided quoting and offload inventory",
    )
    p.add_argument(
        "--offload-last-sec",
        type=float,
        default=60.0,
        help="Seconds before hour-end to stop two-sided quoting and offload inventory (0 = disabled)",
    )

    # Stale data / order guards
    p.add_argument(
        "--stale-book-ms",
        type=float,
        default=5000.0,
        help="Max age of Poly book data before suppressing quotes",
    )
    p.add_argument(
        "--order-max-age-ms",
        type=float,
        default=30000.0,
        help="Max age of a resting order before auto-refresh (0 = disabled)",
    )

    # Reference price decay
    p.add_argument(
        "--bin-ref-decay",
        type=float,
        default=0.001,
        help="Per-tick decay of bin_ref toward current mid (0 = off, 1 = instant)",
    )

    p.add_argument("--quote-interval-ms", type=float, default=15.0)
    p.add_argument("--quote-min-gap-ms", type=float, default=8.0)
    p.add_argument("--fill-poll-ms", type=float, default=150.0)
    p.add_argument("--summary-every-sec", type=float, default=10.0)

    p.add_argument(
        "--max-runtime-sec",
        type=float,
        default=0.0,
        help="0 = forever across hours (rolls internally each hour)",
    )

    # State file / liquidation
    p.add_argument(
        "--state-dir",
        type=str,
        default=".",
        help="Directory to write market state JSON files for the liquidator (default: cwd)",
    )
    p.add_argument(
        "--liquidate-on-roll",
        action="store_true",
        default=True,
        help="Spawn liquidator subprocess after each market roll (default: True)",
    )
    p.add_argument(
        "--no-liquidate-on-roll",
        dest="liquidate_on_roll",
        action="store_false",
        help="Do not spawn the liquidator after market roll",
    )
    p.add_argument(
        "--liquidate-delay-sec",
        type=float,
        default=30.0,
        help="Seconds after market end before the liquidator sells (default: 30)",
    )
    p.add_argument(
        "--liquidate-sell-price",
        type=float,
        default=0.99,
        help="Price at which to sell winning side inventory (default: 0.99)",
    )

    return p.parse_args()


async def main_async(args: argparse.Namespace) -> None:
    load_env_file(args.env_file)

    t0 = time.perf_counter()
    while True:
        # ── Resolve next market with retries ──────────────────────────────
        max_attempts = 12  # 12 × 5s = 60s max wait for market to appear
        last_err: Optional[Exception] = None
        slug: Optional[str] = None
        mk: Optional[dict] = None
        hour_start_et: Optional[datetime] = None

        for attempt in range(max_attempts):
            try:
                slug, mk, hour_start_et = resolve_market_with_hour(
                    args.walk_hours_forward, args.gamma_timeout_sec
                )
                break
            except FileNotFoundError as e:
                last_err = e
                jprint({
                    "event": "resolve_retry",
                    "attempt": attempt + 1,
                    "max_attempts": max_attempts,
                    "err": str(e),
                })
                await asyncio.sleep(5.0)
        else:
            raise FileNotFoundError(
                f"No hourly market found after {max_attempts} attempts"
            ) from last_err

        assert slug is not None and mk is not None and hour_start_et is not None
        up_id, down_id = extract_up_down_token_ids(mk)

        jprint({
            "event": "market_starting",
            "slug": slug,
            "up_id": up_id[:16] + "...",
            "dn_id": down_id[:16] + "...",
            "hour_start_et": hour_start_et.isoformat(),
        })

        # ── Run one hour of market making ─────────────────────────────────
        final_state = await run_one_market(
            args,
            slug=slug,
            up_id=up_id,
            down_id=down_id,
            hour_start_et=hour_start_et,
        )

        # ── Spawn liquidator if enabled and we have inventory ─────────────
        if final_state and args.liquidate_on_roll:
            inv_up = final_state.get("inventory_up", 0)
            inv_dn = final_state.get("inventory_dn", 0)
            if inv_up > 1e-9 or inv_dn > 1e-9:
                liquidator_script = str(
                    Path(__file__).resolve().parent / "market_liquidator.py"
                )
                safe_slug = slug.replace("/", "_").replace("\\", "_")
                state_path = str(
                    Path(args.state_dir) / f"state_{safe_slug}.json"
                )
                try:
                    cmd = [
                        sys.executable,
                        liquidator_script,
                        "--env-file", str(args.env_file),
                        "--state-file", state_path,
                        "--delay-sec", str(args.liquidate_delay_sec),
                        "--sell-price", str(args.liquidate_sell_price),
                        "--tick", str(args.tick),
                    ]
                    if args.live:
                        cmd.append("--live")
                    proc = subprocess.Popen(cmd)
                    jprint({
                        "event": "liquidator_spawned",
                        "pid": proc.pid,
                        "state_file": state_path,
                    })
                except Exception as e:
                    jprint({
                        "event": "liquidator_spawn_error",
                        "err": str(e),
                    })

        # ── Check runtime limit ───────────────────────────────────────────
        if float(args.max_runtime_sec) > 0 and (
            time.perf_counter() - t0
        ) >= float(args.max_runtime_sec):
            jprint({"event": "runtime_limit_reached"})
            return

        # Brief pause before resolving next hour's market
        jprint({"event": "rolling_to_next_market"})
        await asyncio.sleep(2.0)


def main() -> None:
    args = parse_args()
    asyncio.run(main_async(args))


if __name__ == "__main__":
    main()
