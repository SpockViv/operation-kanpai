def softsign(x: float) -> float:
    return x / (1.0 + abs(x))


def clamp(x: float, lo: float, hi: float) -> float:
    return max(lo, min(hi, x))


def _f(x) -> Optional[float]:
    if x is None:
        return None
    v = float(x)
    return v if math.isfinite(v) else None


def _i(x) -> Optional[int]:
    if x is None:
        return None
    try:
        return int(x)
    except Exception:
        return None


def _safe_mid(b: Optional[float], a: Optional[float]) -> Optional[float]:
    if b is None or a is None:
        return None
    return 0.5 * (float(b) + float(a))


