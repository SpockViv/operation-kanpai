    "slope_ref_S_norm_ss",
    "bin_move_from_ref_ss",
]
STATE_DIM = len(FEATURE_NAMES)


def build_feature_vector(
    row: Row,
    args: argparse.Namespace,
    *,
    inv_yes_override: Optional[float] = None,
    inv_no_override: Optional[float] = None,
    inv_notional_override: Optional[float] = None,
) -> np.ndarray:
    t_ms = float(row.t_ms)
    t_ms_norm = (t_ms - float(args.t0_ms)) / max(1.0, float(args.t_norm_ms))

    mono_ns_norm = 0.0
    if row.mono_ns is not None:
        mono_ns_norm = (float(row.mono_ns) - float(args.mono0_ns)) / max(1.0, float(args.mono_norm_ns))

    bin_evt_age_ms = 0.0 if row.bin_evt_ms is None else (t_ms - float(row.bin_evt_ms))
    poly_evt_age_ms = 0.0 if row.poly_evt_ms is None else (t_ms - float(row.poly_evt_ms))
    bin_poly_evt_skew_ms = 0.0
    if row.bin_evt_ms is not None and row.poly_evt_ms is not None:
        bin_poly_evt_skew_ms = float(row.bin_evt_ms) - float(row.poly_evt_ms)

    lag_ratio = float(row.lag_ratio or 0.0)

    yes_mid = row.yes_mid if row.yes_mid is not None else _safe_mid(row.yes_bid, row.yes_ask)
    no_mid = row.no_mid if row.no_mid is not None else _safe_mid(row.no_bid, row.no_ask)

    ybs = float(row.yes_bid_sz or 0.0)
    yas = float(row.yes_ask_sz or 0.0)
    nbs = float(row.no_bid_sz or 0.0)
    nas = float(row.no_ask_sz or 0.0)
    imb_yes = (ybs - yas) / (ybs + yas + 1e-6)
    imb_no = (nbs - nas) / (nbs + nas + 1e-6)

    inv_yes = float(inv_yes_override) if inv_yes_override is not None else float(row.inv_yes or 0.0)
    inv_no = float(inv_no_override) if inv_no_override is not None else float(row.inv_no or 0.0)
    inv_net = inv_yes - inv_no
    inv_gross = inv_yes + inv_no

    inv_notional = float(inv_notional_override) if inv_notional_override is not None else float(row.inv_notional or 0.0)

    cap_yes = max(1.0, float(args.max_yes))
    cap_no = max(1.0, float(args.max_no))
    cap_net = max(1.0, float(args.max_net))

    inv_yes_scaled = inv_yes / cap_yes
    inv_no_scaled = inv_no / cap_no
    inv_net_scaled = inv_net / cap_net
    inv_gross_scaled = inv_gross / max(1.0, cap_yes + cap_no)

    feats = np.asarray(
        [
            float(t_ms_norm),
            float(mono_ns_norm),
            softsign(bin_evt_age_ms / max(1.0, float(args.age_scale_ms))),
            softsign(poly_evt_age_ms / max(1.0, float(args.age_scale_ms))),
            softsign(bin_poly_evt_skew_ms / max(1.0, float(args.age_scale_ms))),
            softsign(lag_ratio),

            float(row.yes_bid or 0.0),
            float(row.yes_ask or 0.0),
            float(row.no_bid or 0.0),
            float(row.no_ask or 0.0),
            float(yes_mid or 0.0),
            float(no_mid or 0.0),
            float(row.spread_yes_c or 0.0),
            float(row.spread_no_c or 0.0),

            softsign(ybs / max(1.0, float(args.sz_scale))),
            softsign(yas / max(1.0, float(args.sz_scale))),
            softsign(nbs / max(1.0, float(args.sz_scale))),
            softsign(nas / max(1.0, float(args.sz_scale))),
            softsign(imb_yes),
            softsign(imb_no),

            softsign(float(row.bin_mid or 0.0) / max(1.0, float(args.bin_mid_scale))),
            softsign(float(row.bin_dS or 0.0) / max(EPS, float(args.bin_dS_scale))),

            float(row.fair_yes or 0.0),
            float((1.0 - float(row.fair_yes)) if row.fair_yes is not None else 0.0),
            softsign(float(row.edge_yes_pp or 0.0) / max(1.0, float(args.edge_scale_pp))),
            softsign(float(row.edge_no_pp or 0.0) / max(1.0, float(args.edge_scale_pp))),
            softsign(float(row.dp_fair_cents or 0.0) / max(1.0, float(args.dp_scale_cents))),
            softsign(float(row.dP_yes_cents or 0.0) / max(1.0, float(args.dp_scale_cents))),
            softsign(float(row.dP_no_cents or 0.0) / max(1.0, float(args.dp_scale_cents))),

            softsign(float(row.sigma_eff or 0.0) / max(EPS, float(args.sigma_scale))),
            softsign(float(row.bin_vol_1h or 0.0) / max(EPS, float(args.sigma_scale))),
            softsign(float(row.T_left_sec or 0.0) / max(1.0, float(args.T_scale_sec))),

            clamp(inv_yes_scaled, -10.0, 10.0),
            clamp(inv_no_scaled, -10.0, 10.0),
            clamp(inv_net_scaled, -10.0, 10.0),
            clamp(inv_gross_scaled, -10.0, 10.0),
            softsign(inv_notional / max(1.0, float(args.notional_scale))),

            softsign((float(row.yes_ask or 0.0) + float(row.no_ask or 0.0) - 1.0) / 0.05),

            float(1.0 if (row.passed_filter or 0) != 0 else 0.0),
            softsign(float(row.strike_k or 0.0) / max(EPS, float(args.K_scale))),
            softsign(float(row.slope_ref_S or 0.0) / max(EPS, float(args.refS_scale))),
            softsign(float(row.bin_move_from_ref or 0.0) / max(EPS, float(args.bin_move_scale))),
        ],
        dtype=np.float32,
    )
    if feats.shape[0] != STATE_DIM:
        raise RuntimeError(f"Feature dim mismatch: got {feats.shape[0]} expected {STATE_DIM}")
    return feats


# ============================================================
# Symmetry augmentation (YES <-> NO)
# ============================================================

def swap_yes_no(row: Row) -> Row:
    yes_bid, no_bid = row.no_bid, row.yes_bid
    yes_ask, no_ask = row.no_ask, row.yes_ask
    yes_mid, no_mid = row.no_mid, row.yes_mid

    yes_bid_sz, no_bid_sz = row.no_bid_sz, row.yes_bid_sz
    yes_ask_sz, no_ask_sz = row.no_ask_sz, row.yes_ask_sz

    spread_yes_c, spread_no_c = row.spread_no_c, row.spread_yes_c

    fair_yes = (1.0 - float(row.fair_yes)) if row.fair_yes is not None else None

    edge_yes_pp, edge_no_pp = row.edge_no_pp, row.edge_yes_pp
    dP_yes_cents, dP_no_cents = row.dP_no_cents, row.dP_yes_cents

    inv_yes, inv_no = row.inv_no, row.inv_yes
    inv_net = None
    if inv_yes is not None or inv_no is not None:
        inv_net = float(inv_yes or 0.0) - float(inv_no or 0.0)
    inv_gross = None
    if inv_yes is not None or inv_no is not None:
        inv_gross = float(inv_yes or 0.0) + float(inv_no or 0.0)

    pnl_1s_yes, pnl_1s_no = row.pnl_1s_no, row.pnl_1s_yes

    return Row(
        row.opp_id,
        row.t_ms,
        row.mono_ns,
        row.bin_evt_ms,
        row.poly_evt_ms,
        row.slug,

        row.no_token_id,
        row.yes_token_id,

        yes_bid, yes_ask, no_bid, no_ask, yes_mid, no_mid,
        yes_bid_sz, yes_ask_sz, no_bid_sz, no_ask_sz,

        spread_yes_c, spread_no_c,
        row.bin_mid,
        row.bin_dS,

        fair_yes,
        edge_yes_pp,
        edge_no_pp,
        row.dp_fair_cents,
        dP_yes_cents,
        dP_no_cents,
        row.lag_ratio,

        inv_yes,
        inv_no,
        inv_net,
        inv_gross,
        row.inv_notional,

        row.sigma_eff,
        row.T_left_sec,

        row.passed_filter,
        row.strike_k,
        row.slope_ref_S,
        row.bin_move_from_ref,
        row.bin_vol_1h,

        pnl_1s_yes,
        pnl_1s_no,
        row.best_pnl_1s,
    )


