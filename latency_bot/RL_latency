def parse_index_list(raw: str, n_slugs: int) -> List[int]:
    indices: List[int] = []
    for part in raw.split(","):
        part = part.strip()
        if not part:
            continue
        if "-" in part:
            lo, hi = part.split("-", 1)
            indices.extend(range(int(lo), int(hi) + 1))
        else:
            indices.append(int(part))
    return [i for i in indices if 0 <= i < n_slugs]


def split_slug_sets(
    ordered_slugs: List[str],
    train_indices: List[int],
    test_indices: List[int],
) -> Tuple[Set[str], Set[str], List[str], List[str]]:
    n = len(ordered_slugs)
    train_slugs = [ordered_slugs[i] for i in train_indices if 0 <= i < n]
    test_slugs = [ordered_slugs[i] for i in test_indices if 0 <= i < n]
    return set(train_slugs), set(test_slugs), train_slugs, test_slugs


