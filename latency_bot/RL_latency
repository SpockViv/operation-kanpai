def _connect_ro(db_path: Path) -> sqlite3.Connection:
    try:
        return sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    except Exception:
        return sqlite3.connect(str(db_path))


def _apply_read_pragmas(conn: sqlite3.Connection) -> None:
    try:
        conn.execute("PRAGMA temp_store=MEMORY;")
        conn.execute("PRAGMA cache_size=-200000;")   # ~200MB (KB units)
        conn.execute("PRAGMA mmap_size=268435456;")  # 256MB
    except Exception:
        pass


def _table_exists(conn: sqlite3.Connection, name: str) -> bool:
    cur = conn.execute(
        "SELECT 1 FROM sqlite_master WHERE type='table' AND name=? LIMIT 1",
        (name,),
    )
    return cur.fetchone() is not None


def _get_columns(conn: sqlite3.Connection, table: str) -> Set[str]:
    cols: Set[str] = set()
    try:
        for _, name, *_ in conn.execute(f"PRAGMA table_info({table})"):
            cols.add(str(name))
    except Exception:
        pass
    return cols


def _ensure_indexes(conn: sqlite3.Connection) -> None:
    try:
        conn.executescript(
            """
            CREATE INDEX IF NOT EXISTS idx_opp_tms        ON opportunities(t_ms);
            CREATE INDEX IF NOT EXISTS idx_opp_slug_tms   ON opportunities(slug, t_ms);
            CREATE INDEX IF NOT EXISTS idx_opp_oppid      ON opportunities(opp_id);
            CREATE INDEX IF NOT EXISTS idx_out_opp_label  ON outcomes(opp_id, label_t_ms);
            """
        )
        conn.commit()
    except Exception:
        pass


def load_ordered_slugs(db_path: Path) -> List[str]:
    db_path = Path(db_path)
    if not db_path.exists():
        raise FileNotFoundError(f"DB not found: {db_path}")

    conn = _connect_ro(db_path)
    _apply_read_pragmas(conn)
    conn.row_factory = None
    q = """
    SELECT slug
    FROM opportunities
    WHERE slug IS NOT NULL AND slug != ''
    GROUP BY slug
    ORDER BY MIN(t_ms) ASC;
    """
    out = [r[0] for r in conn.execute(q)]
    conn.close()
    return out


def load_rows(db_path: Path, *, slug_whitelist: Optional[Set[str]] = None) -> List[Row]:
    db_path = Path(db_path)
    if not db_path.exists():
        raise FileNotFoundError(f"DB not found: {db_path}")

    conn = sqlite3.connect(str(db_path))
    _apply_read_pragmas(conn)
    _ensure_indexes(conn)
    conn.row_factory = None

    if not _table_exists(conn, "opportunities"):
        conn.close()
        raise RuntimeError("DB has no table named 'opportunities'")

    opp_cols = _get_columns(conn, "opportunities")
    has_outcomes = _table_exists(conn, "outcomes")
    out_cols = _get_columns(conn, "outcomes") if has_outcomes else set()

    def ocol(name: str) -> str:
        return f"o.{name} AS {name}" if name in opp_cols else f"NULL AS {name}"

    def ocol_ref(name: str) -> str:
        return f"o.{name}" if name in opp_cols else "NULL"

    def label_expr(name: str) -> str:
        if has_outcomes and name in out_cols:
            return f"oc.{name} AS {name}"
        if name in opp_cols:
            return f"o.{name} AS {name}"
        return f"NULL AS {name}"

    slug_filter_sql = ""
    params: Tuple = ()
    if slug_whitelist:
        wl = [s for s in slug_whitelist if s]
        if wl:
            slug_filter_sql = "WHERE o.slug IN ({})".format(",".join("?" for _ in wl))
            params = tuple(wl)

    join_sql = ""
    if has_outcomes:
        join_sql = """
        LEFT JOIN outcomes oc
          ON oc.opp_id = o.opp_id
         AND oc.label_t_ms = (
              SELECT MAX(oc2.label_t_ms) FROM outcomes oc2 WHERE oc2.opp_id = o.opp_id
         )
        """

    q = f"""
    SELECT
      {ocol("opp_id")},
      {ocol("t_ms")},
      {ocol("mono_ns")},
      {ocol("bin_evt_ms")},
      {ocol("poly_evt_ms")},
      COALESCE({ocol_ref("slug")}, '') AS slug,

      {ocol("yes_token_id")},
      {ocol("no_token_id")},

      {ocol("yes_bid")},
      {ocol("yes_ask")},
      {ocol("no_bid")},
      {ocol("no_ask")},
      {ocol("yes_mid")},
      {ocol("no_mid")},

      {ocol("yes_bid_sz")},
      {ocol("yes_ask_sz")},
      {ocol("no_bid_sz")},
      {ocol("no_ask_sz")},

      {ocol("spread_yes_c")},
      {ocol("spread_no_c")},

      {ocol("bin_mid")},
      {ocol("bin_dS")},

      {ocol("fair_yes")},
      {ocol("edge_yes_pp")},
      {ocol("edge_no_pp")},
      {ocol("dp_fair_cents")},
      {ocol("dP_yes_cents")},
      {ocol("dP_no_cents")},
      {ocol("lag_ratio")},

      {ocol("inv_yes")},
      {ocol("inv_no")},
      {ocol("inv_net")},
      {ocol("inv_gross")},
      {ocol("inv_notional")},

      {ocol("sigma_eff")},
      {ocol("T_left_sec")},

      {ocol("passed_filter")},
      {ocol("strike_k")},
      {ocol("slope_ref_S")},
      {ocol("bin_move_from_ref")},
      {ocol("bin_vol_1h")},

      {label_expr("pnl_1s_yes")},
      {label_expr("pnl_1s_no")},
      {label_expr("best_pnl_1s")}

    FROM opportunities o
    {join_sql}
    {slug_filter_sql}
    ORDER BY o.t_ms;
    """

    rows: List[Row] = []
    app = rows.append
    for t in conn.execute(q, params):
        app(Row(
            int(t[0] or 0),
            int(t[1] or 0),
            _i(t[2]),
            _i(t[3]),
            _i(t[4]),
            str(t[5] or ""),

            (str(t[6]) if t[6] is not None else None),
            (str(t[7]) if t[7] is not None else None),

            _f(t[8]), _f(t[9]), _f(t[10]), _f(t[11]), _f(t[12]), _f(t[13]),
            _f(t[14]), _f(t[15]), _f(t[16]), _f(t[17]),

            _f(t[18]), _f(t[19]),

            _f(t[20]), _f(t[21]),

            _f(t[22]), _f(t[23]), _f(t[24]), _f(t[25]), _f(t[26]), _f(t[27]), _f(t[28]),

            _f(t[29]), _f(t[30]), _f(t[31]), _f(t[32]), _f(t[33]),

            _f(t[34]), _f(t[35]),

            (int(t[36]) if t[36] is not None else None),
            _f(t[37]), _f(t[38]), _f(t[39]), _f(t[40]),

            _f(t[41]), _f(t[42]), _f(t[43]),
        ))
    conn.close()
    return rows


